      {
        "id": "n_la28consent",
        "kind": "evaluate",
        "position": {
          "x": 125,
          "y": 95
        },
        "config": {
          "script": "// Dismiss LA28's first-load consent gate: the \"Legal Terms and Privacy\" modal\n// (a \"CONTINUE\" button, main DOM) and/or a cookie CMP (span#cmpbntyestxt).\n// Waits for full load, then clicks the consent button by id OR by its exact\n// visible text, preferring one inside a modal/overlay, and confirms it closed.\n// Polls up to 60s; if nothing appears it returns and the run continues.\nfunction sleep(ms){return new Promise(function(r){setTimeout(r,ms);});}\nfunction vis(el){\n  if(!el)return false;\n  var r=el.getBoundingClientRect();\n  if(r.width<2||r.height<2)return false;\n  var s=getComputedStyle(el);\n  if(s.visibility==='hidden'||s.display==='none'||parseFloat(s.opacity||'1')<0.05)return false;\n  var W=window.innerWidth||9999,H=window.innerHeight||9999;\n  if(r.bottom<0||r.top>H||r.right<0||r.left>W)return false;\n  return true;\n}\nfunction inOverlay(el){\n  for(var n=el;n&&n!==document.body;n=n.parentElement){\n    if(n.getAttribute&&(n.getAttribute('role')==='dialog'||n.getAttribute('aria-modal')==='true'))return true;\n    var s=getComputedStyle(n);\n    if((s.position==='fixed'||s.position==='sticky')&&parseInt(s.zIndex||'0',10)>=5)return true;\n  }\n  return false;\n}\nfunction clickIt(el){\n  var t=el.closest('button, a, [role=button], input[type=submit], input[type=button], [onclick]')||el;\n  try{t.scrollIntoView({block:'center'});}catch(e){}\n  try{t.click();}catch(e){}\n  if(t!==el){try{el.click();}catch(e){}}\n}\nfunction pickIn(doc){\n  try{\n    var byId=doc.querySelector('#cmpbntyestxt');\n    if(byId&&vis(byId))return byId;\n  }catch(e){}\n  var exact=/^(continue|i agree|agree|accept all|accept cookies|accept|allow all|got it|ok)$/i;\n  var nodes=doc.querySelectorAll('button, a, [role=button], input[type=submit], input[type=button], span, div, p');\n  var best=null;\n  for(var i=0;i<nodes.length;i++){\n    var el=nodes[i];\n    if(!vis(el))continue;\n    var txt=(el.innerText||el.textContent||el.value||'').replace(/\\s+/g,' ').trim();\n    if(!exact.test(txt))continue;\n    var r=el.getBoundingClientRect();\n    if(r.height>140||r.width>800)continue;\n    if(inOverlay(el))return el;\n    if(!best)best=el;\n  }\n  return best;\n}\nfunction pick(){\n  var el=pickIn(document);\n  if(el)return el;\n  var ifr=document.querySelectorAll('iframe');\n  for(var i=0;i<ifr.length;i++){\n    var d=null;try{d=ifr[i].contentDocument;}catch(e){}\n    if(d){var e2=pickIn(d);if(e2)return e2;}\n  }\n  return null;\n}\nvar start=Date.now();\nwhile(document.readyState!=='complete'&&Date.now()-start<15000){await sleep(200);}\nvar deadline=Date.now()+60000;\nwhile(Date.now()<deadline){\n  var el=pick();\n  if(el){\n    clickIt(el);\n    await sleep(700);\n    if(!vis(el))return 'consent-clicked';\n  }\n  await sleep(400);\n}\nreturn 'consent-not-found';",
          "into": "la28Consent"
        }
      }
